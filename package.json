{
  "name": "kau-fpo-platform",
  "version": "0.1.0",
  "description": "AI-Based Digital Platform for KAU-FPO Linkage Programme",
  "author": "Kefi Tech Solutions Pvt Ltd",
  "private": true,
  "scripts": {
    "dev": "set NODE_OPTIONS=--max-old-space-size=1024 && next dev",
    "dev:clean": "pkill -f next-server || true && rm -rf .next && next dev",
    "build": "next build",
    "start": "next start",
    "lint": "biome lint",
    "format": "biome format --write",
    "check": "biome check",
    "check:fix": "biome check --write",
    "prepare": "husky",
    "generate:presets": "ts-node -P tsconfig.scripts.json src/scripts/generate-theme-presets.ts"
  },
  "lint-staged": {
    "*.{js,ts,jsx,tsx}": [
      "biome check --write --no-errors-on-unmatched"
    ]
  },
  "dependencies": {
    "@base-ui/react": "^1.4.0",
